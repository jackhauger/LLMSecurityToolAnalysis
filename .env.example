# =============================================================================
# LLM Security RAG Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Only GOOGLE_API_KEY is required; all others are optional.

# -----------------------------------------------------------------------------
# Google AI (REQUIRED)
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# -----------------------------------------------------------------------------
# LangSmith Observability (optional)
# Get your key at: https://smith.langchain.com
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=llm-security-rag

# -----------------------------------------------------------------------------
# Langfuse Observability (optional)
# Get your keys at: https://cloud.langfuse.com
# -----------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Arize Phoenix Observability (optional)
# Run locally: python -m phoenix.server.main
# -----------------------------------------------------------------------------
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317
PHOENIX_PROJECT_NAME=llm-security-rag

# -----------------------------------------------------------------------------
# ChromaDB Vector Store
# -----------------------------------------------------------------------------
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=mitre_attack

# -----------------------------------------------------------------------------
# Retrieval Configuration
# -----------------------------------------------------------------------------
RETRIEVAL_TOP_K=5
SECURITY_SCORE_THRESHOLD=0.7
